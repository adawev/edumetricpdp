# Copy to .env on the VPS and fill in real values.
# Generate strong secrets:
#   openssl rand -base64 32   (for JWT_SECRET)
#   openssl rand -base64 24   (for POSTGRES_PASSWORD, API_KEY)

POSTGRES_DB=edumetric
POSTGRES_USER=edumetric
POSTGRES_PASSWORD=REPLACE_ME_STRONG

DATABASE_URL=postgresql://edumetric:REPLACE_ME_STRONG@db:5432/edumetric

JWT_SECRET=REPLACE_ME_LONG_RANDOM
API_KEY=REPLACE_ME_LMS_INTEGRATION_KEY
